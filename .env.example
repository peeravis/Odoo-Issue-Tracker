# PostgreSQL connection string
DATABASE_URL="postgresql://issueuser:issuepass@localhost:5432/issuetracker?schema=public"

# JWT signing secret — generate with: openssl rand -base64 32
SESSION_SECRET="change-me-with-openssl-rand-base64-32"

# Public URL of the app — used in assignment email links
# Example: https://odoo-issue-log.scg.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Absolute path for uploaded files (logo, attachments)
# Defaults to <project-root>/uploads if not set
# UPLOAD_DIR="/var/data/issue-tracker/uploads"
